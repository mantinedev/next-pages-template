{
  "printWidth": 100,
  "singleQuote": true,
  "trailingComma": "es5",
  "sortImports": {
    "groups": [
      "side_effect_style",
      "external",
      "internal",
      ["parent", "sibling", "index"],
      "style",
      "unknown"
    ],
    "newlinesBetween": false,
    "order": "asc"
  },
  "sortPackageJson": false,
  "ignorePatterns": [
    "*.d.ts",
    "*.mdx",
    "*.md",
    "packages/*/*/styles.css",
    "packages/*/*/styles.layer.css",
    "packages/*/*/styles/*.css",
    "docs/.next",
    "docs/out"
  ]
}
